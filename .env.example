AZURE_OPENAI_API_VERSION="2025-03-01-preview"

AZURE_OPENAI_ENDPOINT="https://your-endpoint.openai.azure.com"
AZURE_OPENAI_DEPLOYMENTS="gpt-4.1-001, gpt-4.1-002" # comma-separated list of deployment names to use multiple deployments for load balancing
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENTS="text-embedding-3-small-001, text-embedding-3-small-002"

# Additional Azure OpenAI endpoints (optional, for pooled client)
# AZURE_OPENAI_ENDPOINT_2="https://your-endpoint-2.openai.azure.com"
# AZURE_OPENAI_DEPLOYMENTS_2="gpt-4.1-001, gpt-4.1-002"
