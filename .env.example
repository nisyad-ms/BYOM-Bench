# AZURE_OPENAI_EMBEDDINGS_DEPLOYMENTS_3="text-embedding-3-small-001"

# Azure AI Foundry (for foundry agent)
# AZURE_FOUNDRY_ENDPOINT="https://your-endpoint.services.ai.azure.com/api/projects/your-project"
# AZURE_FOUNDRY_DEPLOYMENTS="gpt-4.1-001, gpt-4.1-002"
# AZURE_FOUNDRY_EMBEDDINGS_DEPLOYMENTS="text-embedding-3-small-001"

# AZURE_FOUNDRY_ENDPOINT_2="https://your-endpoint-2.services.ai.azure.com/api/projects/your-project"
