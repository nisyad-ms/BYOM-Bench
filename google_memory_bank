"""Standalone Google Vertex AI Memory Bank client.

Provides a simple interface for adding, retrieving, and clearing memories
using Google Vertex AI Agent Engine's memory service.

Requires:
    pip install google-cloud-aiplatform python-dotenv

Environment variables:
    GCLOUD_PROJECT_ID  — Google Cloud project ID
    GCLOUD_LOCATION    — Region (default: us-central1)
"""

from __future__ import annotations

import logging
import os
from typing import Any, Dict, List, Optional

import vertexai
from dotenv import load_dotenv

load_dotenv()

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


class GoogleMemoryBank:
    """Lightweight wrapper around Google Vertex AI Agent Engine memories."""

    def __init__(
        self,
        project_id: Optional[str] = None,
        location: Optional[str] = None,
    ) -> None:
        self.project_id = project_id or os.environ.get("GCLOUD_PROJECT_ID")
        self.location = location or os.environ.get("GCLOUD_LOCATION", "us-central1")
        if not self.project_id:
            raise ValueError(
                "project_id must be provided or set via GCLOUD_PROJECT_ID env var"
            )

        self.client = vertexai.Client(project=self.project_id, location=self.location)
        self._agent_engine: Any = None
        self._agent_engine_name: Optional[str] = None

    # ------------------------------------------------------------------
    # Agent engine lifecycle
    # ------------------------------------------------------------------

    def _ensure_engine(self) -> None:
        """Create or reuse the agent engine."""
        if self._agent_engine is not None:
            return

        memory_config: Dict = {
            "customization_configs": [
                {
                    "memory_topics": [
                        {"managed_memory_topic": {"managed_topic_enum": "USER_PERSONAL_INFO"}},
                        {"managed_memory_topic": {"managed_topic_enum": "USER_PREFERENCES"}},
                        {"managed_memory_topic": {"managed_topic_enum": "KEY_CONVERSATION_DETAILS"}},
                        {"managed_memory_topic": {"managed_topic_enum": "EXPLICIT_INSTRUCTIONS"}},
                    ]
                }
            ]
        }

        self._agent_engine = self.client.agent_engines.create(
            config={"context_spec": {"memory_bank_config": memory_config}}
        )
        self._agent_engine_name = self._agent_engine.api_resource.name
        logger.info("Created agent engine: %s", self._agent_engine_name)

    # ------------------------------------------------------------------
    # Public API
    # ------------------------------------------------------------------

    @staticmethod
    def _memory_to_dict(memory: Any) -> Dict:
        """Extract all available fields from a Memory object."""
        result: Dict[str, Any] = {"fact": memory.fact}
        if hasattr(memory, "name") and memory.name:
            result["name"] = memory.name
        if hasattr(memory, "topics") and memory.topics:
            topics = []
            for t in memory.topics:
                managed = getattr(t, "managed_memory_topic", None)
                if managed:
                    topics.append(managed.value if hasattr(managed, "value") else str(managed))
                else:
                    label = getattr(t, "custom_memory_topic_label", None)
                    topics.append(label or str(t))
            result["topics"] = topics
        if hasattr(memory, "create_time") and memory.create_time:
            result["create_time"] = str(memory.create_time)
        if hasattr(memory, "update_time") and memory.update_time:
            result["update_time"] = str(memory.update_time)
        return result

    def add_memories(
        self,
        user_id: str,
        messages: List[Dict[str, str]],
    ) -> List[Dict]:
        """Store memories extracted from a conversation.

        Args:
            user_id: Unique identifier for the user.
            messages: List of ``{"role": "user"|"assistant", "content": "..."}`` dicts.

        Returns:
            List of memory dicts with keys: fact, name, topics, create_time, update_time.
        """
        self._ensure_engine()

        vertex_messages = []
        for msg in messages:
            role = "user" if msg["role"] in ("user", "system") else "model"
            vertex_messages.append(
                {"content": {"role": role, "parts": [{"text": msg["content"]}]}}
            )

        result = self.client.agent_engines.memories.generate(
            name=self._agent_engine_name,
            direct_contents_source={"events": vertex_messages},
            scope={"user_id": user_id},
            config={"wait_for_completion": True},
        )

        if result is None or result.response is None:
            logger.info("No memories generated.")
            return []

        memories: List[Dict] = []
        for mem in result.response.generated_memories:
            content = self.client.agent_engines.memories.get(name=mem.memory.name)
            memories.append(self._memory_to_dict(content))

        logger.info("Stored %d memories for user %s", len(memories), user_id)
        return memories

    def retrieve_memories(
        self,
        user_id: str,
        num_memories: int = 10,
        query: Optional[str] = None,
    ) -> List[Dict]:
        """Retrieve memories for a user.

        Args:
            user_id: Unique identifier for the user.
            num_memories: Maximum number of memories to return.
            query: If provided, performs similarity search; otherwise lists all.

        Returns:
            List of memory dicts with keys: fact, name, topics, create_time, update_time.
        """
        self._ensure_engine()

        if query:
            results = self.client.agent_engines.memories.retrieve(
                name=self._agent_engine_name,
                scope={"user_id": user_id},
                similarity_search_params={
                    "search_query": query,
                    "top_k": num_memories,
                },
            )
        else:
            results = list(
                self.client.agent_engines.memories.retrieve(
                    name=self._agent_engine_name,
                    scope={"user_id": user_id},
                )
            )

        memories = [self._memory_to_dict(m.memory) for m in results][:num_memories]
        logger.info(
            "Retrieved %d memories for user %s (query=%s)",
            len(memories),
            user_id,
            query,
        )
        return memories

    def clear_memories(self, user_id: str) -> None:  # noqa: ARG002
        """Delete the agent engine to clear all memories.

        Note: Vertex AI does not currently support per-user memory deletion,
        so this deletes the entire engine.
        """
        if self._agent_engine_name is None:
            logger.warning("No agent engine to delete.")
            return

        logger.warning(
            "Deleting entire agent engine (per-user deletion not supported). "
            "All users' memories will be removed."
        )
        self.client.agent_engines.delete(
            name=self._agent_engine_name, force=True
        )
        logger.info("Deleted agent engine: %s", self._agent_engine_name)
        self._agent_engine = None
        self._agent_engine_name = None

    def cleanup(self) -> None:
        """Explicitly clean up the agent engine resource."""
        if self._agent_engine_name is None:
            return
        try:
            self.client.agent_engines.delete(
                name=self._agent_engine_name, force=True
            )
            logger.info("Cleaned up agent engine: %s", self._agent_engine_name)
        except Exception as e:
            if "404" in str(e) or "NOT_FOUND" in str(e):
                logger.info("Agent engine already deleted.")
            else:
                raise
        finally:
            self._agent_engine = None
            self._agent_engine_name = None


# ----------------------------------------------------------------------
# Demo
# ----------------------------------------------------------------------

if __name__ == "__main__":
    bank = GoogleMemoryBank()

    sample_messages = [
        {"role": "user", "content": "Hi, my name is Alice and I live in Seattle."},
        {"role": "assistant", "content": "Nice to meet you, Alice! Seattle is a great city."},
        {"role": "user", "content": "I love hiking and prefer dark-roast coffee."},
        {"role": "assistant", "content": "Hiking and dark-roast coffee — great combo!"},
    ]

    user = "alice-demo"

    print("\n--- Adding memories ---")
    facts = bank.add_memories(user, sample_messages)
    for f in facts:
        print(f"  • {f['fact']}  (topics={f.get('topics', [])})")

    print("\n--- Retrieving all memories ---")
    all_mems = bank.retrieve_memories(user, num_memories=10)
    for m in all_mems:
        print(f"  • {m['fact']}  (topics={m.get('topics', [])})")

    print("\n--- Similarity search: 'coffee' ---")
    search_mems = bank.retrieve_memories(user, num_memories=5, query="coffee")
    for m in search_mems:
        print(f"  • {m['fact']}  (topics={m.get('topics', [])})")

    print("\n--- Cleaning up ---")
    bank.cleanup()
